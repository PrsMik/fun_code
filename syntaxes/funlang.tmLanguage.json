{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "FunLang",
    "patterns": [
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#booleans"
        }
    ],
    "repository": {
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.funlang",
                    "match": "\\b(let|fn|return|if|else)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "entity.name.type.funlang",
                    "match": "\\b(int|bool|string)\\b"
                }
            ]
        },
        "booleans": {
            "patterns": [
                {
                    "name": "constant.language.boolean.funlang",
                    "match": "\\b(true|false)\\b"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.funlang",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.funlang",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.funlang",
                    "match": "\\\\."
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.funlang",
                    "match": "(==|!=|<=|>=|<|>|=|\\+|-|\\*|/|&&|\\|\\||!|<-|->)"
                }
            ]
        }
    },
    "scopeName": "source.funlang"
}